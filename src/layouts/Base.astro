---
import '../styles/global.css';
const { title = 'Varun Nair', description = 'Solutions Architect. Writing about telecoms, cloud and AI.' } = Astro.props;
const path = Astro.url.pathname;
const nav = [
  { label: 'About',        href: '/about' },
  { label: 'Work',         href: '/work' },
  { label: 'Writing',      href: '/writing' },
  { label: 'Research',     href: '/research' },
  { label: 'Contact',      href: '/contact' },
];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Varun Nair</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
</head>
<body>

  <header class="site-header">
    <nav class="container--wide nav-inner">
      <a href="/" class="nav-logo">Varun Nair</a>
      <ul class="nav-links">
        {nav.map(n => (
          <li>
            <a href={n.href} class:list={['nav-link', { 'nav-link--active': path.startsWith(n.href) }]}>
              {n.label}
            </a>
          </li>
        ))}
      </ul>
      <button class="nav-burger" id="burger" aria-label="Menu">
        <span></span><span></span>
      </button>
    </nav>
    <div class="nav-mobile" id="mobile-nav">
      {nav.map(n => (
        <a href={n.href} class="nav-mobile-link">{n.label}</a>
      ))}
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container--wide footer-inner">
      <p class="footer-name">Varun Nair</p>
      <p class="footer-sub">Solutions Architect · Zoetermeer, Netherlands</p>
      <div class="footer-links">
        <a href="https://github.com/VarunDelft" target="_blank" rel="noopener">GitHub</a>
        <a href="https://www.linkedin.com/in/varunnair1/" target="_blank" rel="noopener">LinkedIn</a>
        <a href="https://twitter.com/Var92" target="_blank" rel="noopener">Twitter</a>
        <a href="/writing">Writing</a>
      </div>
      <p class="footer-copy">© {new Date().getFullYear()} Varun Nair</p>
    </div>
  </footer>

  <script>
    const burger = document.getElementById('burger');
    const mobileNav = document.getElementById('mobile-nav');
    burger?.addEventListener('click', () => {
      mobileNav?.classList.toggle('open');
      burger.classList.toggle('open');
    });
  </script>

</body>
</html>

<style>
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(250, 250, 248, 0.92);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--rule);
}
.nav-inner {
  display: flex;
  align-items: center;
  height: var(--nav-h);
  gap: 2rem;
}
.nav-logo {
  font-family: var(--font-serif);
  font-size: 1.1rem;
  color: var(--ink);
  text-decoration: none;
  flex-shrink: 0;
  margin-right: auto;
}
.nav-logo:hover { opacity: 1; }
.nav-links {
  display: flex;
  list-style: none;
  gap: 0.25rem;
}
.nav-link {
  font-size: 0.8rem;
  font-weight: 400;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: var(--ink-tertiary);
  padding: 0.4rem 0.75rem;
  border-radius: 6px;
  transition: color 0.15s, background 0.15s;
  text-decoration: none;
}
.nav-link:hover {
  color: var(--ink);
  background: var(--paper-secondary);
  opacity: 1;
}
.nav-link--active {
  color: var(--ink);
  background: var(--paper-secondary);
}
.nav-burger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
}
.nav-burger span {
  display: block;
  width: 22px;
  height: 1.5px;
  background: var(--ink);
  transition: transform 0.2s, opacity 0.2s;
}
.nav-burger.open span:first-child { transform: translateY(6.5px) rotate(45deg); }
.nav-burger.open span:last-child  { transform: translateY(-6.5px) rotate(-45deg); }
.nav-mobile {
  display: none;
  flex-direction: column;
  border-top: 1px solid var(--rule);
  padding: 0.75rem 1.5rem 1rem;
  gap: 0.25rem;
}
.nav-mobile.open { display: flex; }
.nav-mobile-link {
  font-size: 0.95rem;
  color: var(--ink-secondary);
  padding: 0.5rem 0;
  text-decoration: none;
  border-bottom: 1px solid var(--rule);
}

.site-footer {
  margin-top: 6rem;
  border-top: 1px solid var(--rule);
  padding: 3rem 0;
}
.footer-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  text-align: center;
}
.footer-name {
  font-family: var(--font-serif);
  font-size: 1rem;
  color: var(--ink);
}
.footer-sub {
  font-size: 0.8rem;
  color: var(--ink-tertiary);
}
.footer-links {
  display: flex;
  gap: 1.5rem;
  margin: 0.5rem 0;
}
.footer-links a {
  font-size: 0.8rem;
  color: var(--ink-tertiary);
  text-decoration: none;
}
.footer-links a:hover { color: var(--accent); opacity: 1; }
.footer-copy {
  font-size: 0.75rem;
  color: var(--ink-tertiary);
  margin-top: 0.5rem;
}

@media (max-width: 640px) {
  .nav-links { display: none; }
  .nav-burger { display: flex; }
}
</style>
