---
import Base from '../layouts/Base.astro';
---
<Base title="Contact" description="Get in touch with Varun Nair.">

  <div class="container page-wrap">

    <header class="page-header fade-up">
      <p class="page-eyebrow">Contact</p>
      <h1>Get in touch</h1>
      <p class="page-sub">Open to interesting conversations, collaborations and opportunities.</p>
    </header>

    <div class="contact-grid fade-up fade-up-1">

      <div class="contact-channels">
        <a href="mailto:nair.varun1992@gmail.com" class="channel-card">
          <span class="channel-label">Email</span>
          <span class="channel-value">nair.varun1992@gmail.com</span>
          <span class="channel-arrow">→</span>
        </a>
        <a href="https://www.linkedin.com/in/varunnair1/" target="_blank" rel="noopener" class="channel-card">
          <span class="channel-label">LinkedIn</span>
          <span class="channel-value">linkedin.com/in/varunnair1</span>
          <span class="channel-arrow">→</span>
        </a>
        <a href="https://github.com/VarunDelft" target="_blank" rel="noopener" class="channel-card">
          <span class="channel-label">GitHub</span>
          <span class="channel-value">github.com/VarunDelft</span>
          <span class="channel-arrow">→</span>
        </a>
        <a href="https://twitter.com/Var92" target="_blank" rel="noopener" class="channel-card">
          <span class="channel-label">Twitter / X</span>
          <span class="channel-value">@Var92</span>
          <span class="channel-arrow">→</span>
        </a>
      </div>

      <div class="contact-note">
        <p>
          I'm currently based in Zoetermeer, Netherlands, and working as a consultant
          in the telecoms space. If you're working on something interesting in network
          automation, cloud, or AI and want to think through it together — feel free
          to reach out.
        </p>
        <p>
          Response time varies but I do read everything.
        </p>
      </div>

    </div>

  </div>

</Base>

<style>
.page-wrap { padding: 5rem 0 4rem; }
.page-header { margin-bottom: 4rem; }
.page-eyebrow {
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink-tertiary);
  margin-bottom: 1rem;
}
.page-header h1 { font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 0.5rem; }
.page-sub { font-size: 1rem; color: var(--ink-tertiary); }

.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: start;
}

.contact-channels { display: flex; flex-direction: column; gap: 0; }
.channel-card {
  display: grid;
  grid-template-columns: 90px 1fr 20px;
  align-items: center;
  gap: 1rem;
  padding: 1.25rem 0;
  border-top: 1px solid var(--rule);
  text-decoration: none;
  color: inherit;
  transition: background 0.15s;
}
.channel-card:last-child { border-bottom: 1px solid var(--rule); }
.channel-card:hover .channel-value { color: var(--accent); }
.channel-card:hover .channel-arrow { transform: translateX(3px); color: var(--accent); }
.channel-label {
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--ink-tertiary);
}
.channel-value {
  font-size: 0.875rem;
  color: var(--ink-secondary);
  transition: color 0.15s;
}
.channel-arrow {
  font-size: 0.9rem;
  color: var(--ink-tertiary);
  transition: transform 0.15s, color 0.15s;
}

.contact-note { padding-top: 0.5rem; }
.contact-note p {
  font-size: 0.95rem;
  color: var(--ink-tertiary);
  line-height: 1.8;
  margin-bottom: 1.25rem;
}

@media (max-width: 620px) {
  .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  .channel-card { grid-template-columns: 80px 1fr 16px; }
}
</style>
