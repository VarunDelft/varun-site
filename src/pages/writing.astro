---
import Base from '../layouts/Base.astro';
const posts = await Astro.glob('./blog/*.{md,mdx}');
const sorted = posts.sort((a, b) =>
  new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);
---
<Base title="Writing" description="Blog posts and essays by Varun Nair on telecoms, Java, cloud and AI.">

  <div class="container page-wrap">

    <header class="page-header fade-up">
      <p class="page-eyebrow">Writing</p>
      <h1>Blog & essays</h1>
      <p class="page-sub">
        Notes on software, networks, and whatever I'm thinking about.
      </p>
    </header>

    {sorted.length === 0 ? (
      <div class="empty-state fade-up fade-up-1">
        <p>No posts yet — check back soon.</p>
        <p class="empty-hint">
          Add <code>.md</code> or <code>.mdx</code> files to
          <code>src/content/blog/</code> to start publishing.
        </p>
      </div>
    ) : (
      <ul class="post-list fade-up fade-up-1">
        {sorted.map(post => {
          const { title, description, date, tags = [] } = post.frontmatter;
          const formatted = new Date(date).toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' });
          return (
            <li class="post-item">
              <a href={post.url} class="post-link">
                <div class="post-date">{formatted}</div>
                <div class="post-main">
                  <h2 class="post-title">{title}</h2>
                  {description && <p class="post-desc">{description}</p>}
                  <div class="post-tags">
                    {tags.map((t: string) => <span class="tag">{t}</span>)}
                  </div>
                </div>
                <span class="post-arrow">→</span>
              </a>
            </li>
          );
        })}
      </ul>
    )}

  </div>

</Base>

<style>
.page-wrap { padding: 5rem 0 4rem; }
.page-header { margin-bottom: 4rem; }
.page-eyebrow {
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink-tertiary);
  margin-bottom: 1rem;
}
.page-header h1 { font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 0.5rem; }
.page-sub { font-size: 1rem; color: var(--ink-tertiary); }

.empty-state {
  padding: 3rem 0;
  border-top: 1px solid var(--rule);
  border-bottom: 1px solid var(--rule);
}
.empty-state p { font-size: 0.95rem; color: var(--ink-tertiary); margin-bottom: 0.5rem; }
.empty-hint { font-size: 0.85rem; color: var(--ink-tertiary); }
.empty-hint code {
  font-size: 0.8em;
  background: var(--paper-secondary);
  border: 1px solid var(--rule);
  border-radius: 4px;
  padding: 0.1em 0.35em;
}

.post-list { list-style: none; }
.post-item { border-top: 1px solid var(--rule); }
.post-item:last-child { border-bottom: 1px solid var(--rule); }
.post-link {
  display: grid;
  grid-template-columns: 110px 1fr 24px;
  gap: 1.5rem;
  align-items: start;
  padding: 1.75rem 0;
  text-decoration: none;
  color: inherit;
  transition: background 0.15s;
}
.post-link:hover { opacity: 1; }
.post-link:hover .post-title { color: var(--accent); }
.post-link:hover .post-arrow { color: var(--accent); transform: translateX(3px); }

.post-date {
  font-size: 0.75rem;
  color: var(--ink-tertiary);
  padding-top: 0.2rem;
  font-variant-numeric: tabular-nums;
}
.post-title {
  font-family: var(--font-serif);
  font-size: 1.1rem;
  font-weight: 400;
  color: var(--ink);
  margin-bottom: 0.4rem;
  transition: color 0.15s;
  line-height: 1.3;
}
.post-desc {
  font-size: 0.875rem;
  color: var(--ink-tertiary);
  line-height: 1.6;
  margin-bottom: 0.6rem;
}
.post-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }
.post-arrow {
  font-size: 1rem;
  color: var(--ink-tertiary);
  padding-top: 0.15rem;
  transition: color 0.15s, transform 0.15s;
}

@media (max-width: 520px) {
  .post-link { grid-template-columns: 1fr; gap: 0.4rem; }
  .post-arrow { display: none; }
}
</style>
